<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LinkSentry.ViewModels"
        xmlns:models="using:LinkSentry.Models"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="LinkSentry.MainWindow"
        x:DataType="vm:MainViewModel"
        x:Name="MainWindowRoot"
        Title="NetPulse - 连线卫士 (网络诊断工具)">
        
    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover">
            <Setter Property="Background" Value="#201E90FF" />
        </Style>
    </Window.Styles>
    
    <Window.Resources>
    </Window.Resources>
    
    <Grid ColumnDefinitions="60,*">
        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="0,15" CornerRadius="0" BoxShadow="2 0 8 0 #30000000">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Logo / Brand -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,5,0,20">
                    <Border Background="#1E90FF" CornerRadius="12" Width="40" Height="40" 
                            HorizontalAlignment="Center">
                        <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                
                <!-- Navigation Icons -->
                <StackPanel Grid.Row="1" Spacing="10" HorizontalAlignment="Center">
                    <!-- Dashboard -->
                    <Button Classes="nav-btn" Width="42" Height="42" 
                            ToolTip.Tip="仪表盘"
                            Command="{Binding NavigateToCommand}" CommandParameter="dashboard">
                        <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    
                    <!-- Security & Ports -->
                    <Button Classes="nav-btn" Width="42" Height="42" 
                            ToolTip.Tip="安全与端口"
                            Command="{Binding NavigateToCommand}" CommandParameter="security">
                        <TextBlock Text="🛡️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    
                    <Separator Margin="5,5" Background="#20000000"/>
                    
                    <!-- Refresh -->
                    <Button Classes="nav-btn" Width="42" Height="42" 
                            ToolTip.Tip="刷新数据" Command="{Binding RefreshAllCommand}">
                        <TextBlock Text="🔄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <!-- Bottom: Settings -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <Button Classes="nav-btn" Width="42" Height="42" ToolTip.Tip="设置">
                        <TextBlock Text="⚙️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right: Main Content Area -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="NetPulse" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#1E90FF" />
                        <Separator Width="1" Height="20" Background="#40808080" Margin="5,0"/>
                        <TextBlock x:Name="PageTitleText" Text="仪表盘" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>

                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" VerticalAlignment="Center" Width="120" Height="4"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content -->
            <ContentControl x:Name="PageContent" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>


